NODE_ENV=production
PORT=8787

# Comma-separated list allowed. Do not use * in production.
CORS_ORIGIN=https://app.example.com

JWT_SECRET=replace-with-long-random-secret
JWT_EXPIRES_SECONDS=3600
JWT_REFRESH_EXPIRES_SECONDS=86400
AUTH_ACCESS_TOKEN_TTL_SECONDS=900
AUTH_REFRESH_TOKEN_TTL_SECONDS=1209600

# Required in production
DATABASE_URL=postgres://trading:replace-password@127.0.0.1:5432/trading_cockpit

# Optional but recommended
REDIS_URL=redis://127.0.0.1:6379

RATE_LIMIT_WINDOW_SECONDS=60
RATE_LIMIT_MAX_REQUESTS=240
CACHE_PUBLICFLOW_TTL_SECONDS=30

# Optional providers
OLLAMA_CLOUD_ENDPOINT=https://ollama.com/api
OLLAMA_CLOUD_API_KEY=
OPENAI_API_KEY=
GOOGLE_GEMINI_API_KEY=
MICROSOFT_COPILOT_API_KEY=
ANTHROPIC_API_KEY=
