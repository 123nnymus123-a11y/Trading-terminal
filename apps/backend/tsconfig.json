{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "outDir": "dist",
    "rootDir": "src",
    "types": ["node"],
    "declaration": false,
    "sourceMap": true,
    "noEmit": false,
    "paths": {
      "@tc/shared/tedIntel": ["../../packages/shared/src/tedIntel.ts"],
      "@tc/api": ["../../packages/api/src/index.ts"],
      "@tc/api/*": ["../../packages/api/src/*"]
    }
  },
  "include": ["src/**/*.ts"]
}
