# Copy this file to .env.local and fill in your values.
# Never commit .env.local — it is listed in .gitignore.

# Backend URL (points to your Trading Cockpit backend)
VITE_TC_BACKEND_URL=http://localhost:8787

# Optional: dev auto-login (remove or leave blank in production)
VITE_TC_BOOTSTRAP_EMAIL=
VITE_TC_BOOTSTRAP_PASSWORD=
VITE_TC_BOOTSTRAP_LICENSE_KEY=
