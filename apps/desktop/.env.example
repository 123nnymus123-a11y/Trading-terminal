# Copy this file to .env.local and fill in your values.
# Never commit .env.local — it is listed in .gitignore.

# Backend URL (points to your Trading Cockpit backend)
VITE_TC_BACKEND_URL=http://localhost:8787

# Cloud AI Provider Configuration
# Supported: openai
CLOUD_AI_PROVIDER=openai

# OpenAI (required when CLOUD_AI_PROVIDER=openai)
# Get your key at: https://platform.openai.com/api-keys
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o

# AI request tuning (optional, defaults shown)
# AI_REQUEST_TIMEOUT_MS=30000
# AI_MAX_RETRIES=2

# Optional: dev auto-login (remove or leave blank in production)
VITE_TC_BOOTSTRAP_EMAIL=
VITE_TC_BOOTSTRAP_PASSWORD=
VITE_TC_BOOTSTRAP_LICENSE_KEY=

# Graph Enrichment Memory System (local-first, cloud-ready placeholders)
# Leave CLOUD_ENABLED=false for local-only mode.
LOCAL_DB_PATH=
EXPORT_PATH=
CLOUD_ENABLED=false
CLOUD_PROVIDER=placeholder
CLOUD_DB_URL=
CLOUD_BUCKET=
CLOUD_SYNC_MODE=manual
CLOUD_PROJECT_ID=
