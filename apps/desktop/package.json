{
  "name": "@tc/desktop",
  "private": true,
  "version": "0.0.19",
  "description": "Trading Terminal Desktop Application",
  "author": "Trading Terminal",
  "repository": {
    "type": "git",
    "url": "https://github.com/123nnymus123-a11y/Trading-terminal.git"
  },
  "type": "module",
  "main": "dist/main/index.cjs",
  "scripts": {
    "postinstall": "node scripts/postinstall-rebuild.mjs",
    "dev": "node scripts/dev.mjs",
    "dev:renderer": "vite --config vite.renderer.config.ts --host 127.0.0.1 --port 5173 --strictPort",
    "rebuild:native": "electron-rebuild -f -w better-sqlite3,keytar",
    "build": "node scripts/build.mjs",
    "build:installer": "node scripts/build-installer.mjs",
    "build:win": "node scripts/build-installer.mjs",
    "release:github": "pnpm exec electron-builder --config electron-builder.config.cjs --win nsis --publish always",
    "build:renderer": "vite build --config vite.renderer.config.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "echo \"lint not configured yet\"",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@react-three/fiber": "^9.5.0",
    "@xyflow/react": "^12.0.0",
    "adm-zip": "^0.5.12",
    "better-sqlite3": "^12.6.2",
    "cheerio": "^1.2.0",
    "dotenv": "^17.2.3",
    "electron-updater": "^6.8.3",
    "fast-xml-parser": "^4.3.6",
    "keytar": "^7.9.0",
    "lightweight-charts": "^4.2.0",
    "maplibre-gl": "^5.16.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.22.3",
    "three": "^0.182.0",
    "zod": "^4.0.5",
    "zustand": "^4.5.5"
  },
  "devDependencies": {
    "@electron/rebuild": "^3.7.1",
    "@tc/shared": "workspace:*",
    "@types/node": "^20.11.30",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.2.1",
    "electron": "30.5.1",
    "electron-builder": "^25.1.8",
    "esbuild": "^0.25.0",
    "typescript": "^5.6.3",
    "vite": "^5.4.21",
    "vitest": "^1.2.0"
  }
}